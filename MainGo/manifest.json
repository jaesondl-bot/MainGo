{
  "manifest_version": 3,
  "name": "MainGo",
  "version": "1.1.0",
  "description": "The bridge: one tap, no sign-in. Opens your music app on a varied genre search. No tracking.",
  "permissions": ["sidePanel", "tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "MainGo — open panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
